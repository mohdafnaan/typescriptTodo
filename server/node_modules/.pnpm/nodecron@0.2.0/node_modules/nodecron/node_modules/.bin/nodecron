#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/afnaan/typescriptTodo/server/node_modules/.pnpm/nodecron@0.2.0/node_modules/nodecron/bin/node_modules:/home/afnaan/typescriptTodo/server/node_modules/.pnpm/nodecron@0.2.0/node_modules/nodecron/node_modules:/home/afnaan/typescriptTodo/server/node_modules/.pnpm/nodecron@0.2.0/node_modules:/home/afnaan/typescriptTodo/server/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/afnaan/typescriptTodo/server/node_modules/.pnpm/nodecron@0.2.0/node_modules/nodecron/bin/node_modules:/home/afnaan/typescriptTodo/server/node_modules/.pnpm/nodecron@0.2.0/node_modules/nodecron/node_modules:/home/afnaan/typescriptTodo/server/node_modules/.pnpm/nodecron@0.2.0/node_modules:/home/afnaan/typescriptTodo/server/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/nodecron" "$@"
else
  exec node  "$basedir/../../bin/nodecron" "$@"
fi
